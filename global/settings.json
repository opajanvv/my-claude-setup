{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Skill(evaluate)",
      "Skill(plan)",
      "Skill(review-text)",
      "Bash(gh auth status:*)",
      "Bash(gh repo create:*)",
      "Bash(git init:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git fetch:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git show:*)",
      "Bash(git remote:*)",
      "Bash(git stash:*)",
      "Bash(git tag:*)",
      "Bash(~/.local/bin/calendar-today:*)",
      "WebFetch(domain:tasks.janvv.nl)",
      "Bash(python3:*)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(shuf:*)",
      "Bash(xargs:*)",
      "Bash(awk:*)",
      "Bash(find:*)",
      "Bash(for dir in */)",
      "WebSearch",
      "Bash(/home/jan/.local/share/uv/tools/gcalcli/bin/pip list)",
      "Bash(uv tool install:*)",
      "Bash(gcalcli:*)",
      "WebFetch(domain:www.producttalk.org)",
      "Bash(for:*)",
      "Bash(do mv \"$f\" ../blog/)",
      "Bash(done)",
      "Bash(readlink:*)",
      "Bash(git restore:*)",
      "Bash(git rm:*)",
      "Bash(pgrep:*)",
      "Bash(mount:*)",
      "Bash(crontab:*)",
      "Bash(systemctl list-timers:*)",
      "Bash(systemctl:*)",
      "Bash(sudo sed:*)",
      "Bash(git -C /home/jan/dev/mystrap/dotfiles/claude log --oneline -10)",
      "WebFetch(domain:obsidian.md)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:medium.com)",
      "Bash(getent:*)"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/generate-dates.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/log-skill-usage.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "editorMode": "normal",
  "model": "claude-fable-5[1m]"
}
